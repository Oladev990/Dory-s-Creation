<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Friendly" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Couleurs primaires -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryContainer">@color/primary_light</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>
        
        <!-- Couleurs secondaires -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_light</item>
        <item name="colorOnSecondary">@color/text_on_secondary</item>
        <item name="colorOnSecondaryContainer">@color/text_primary</item>
        
        <!-- Couleurs tertiaires -->
        <item name="colorTertiary">@color/accent</item>
        <item name="colorTertiaryContainer">@color/accent_dark</item>
        <item name="colorOnTertiary">@color/text_primary</item>
        <item name="colorOnTertiaryContainer">@color/text_primary</item>
        
        <!-- Couleurs de surface -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        
        <!-- Couleurs d'erreur -->
        <item name="colorError">@color/error</item>
        <item name="colorErrorContainer">@color/error</item>
        <item name="colorOnError">@color/text_on_primary</item>
        <item name="colorOnErrorContainer">@color/text_on_primary</item>
        
        <!-- Couleurs de fond -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/text_primary</item>
        
        <!-- Couleurs d'ombre -->
        <item name="colorShadow">@color/shadow</item>
        <item name="colorOutline">@color/text_hint</item>
        <item name="colorOutlineVariant">@color/surface_dark</item>
        
        <!-- Statut bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        
        <!-- Typographie -->
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.Friendly.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.Friendly.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.Friendly.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.Friendly.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.Friendly.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.Friendly.TitleSmall</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.Friendly.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.Friendly.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.Friendly.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.Friendly.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.Friendly.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.Friendly.LabelSmall</item>
    </style>
    
    <!-- Styles de typographie -->
    <style name="TextAppearance.Friendly.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">32sp</item>
        <item name="android:fontFamily">@font/poppins_bold</item>
    </style>
    
    <style name="TextAppearance.Friendly.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">28sp</item>
        <item name="android:fontFamily">@font/poppins_semibold</item>
    </style>
    
    <style name="TextAppearance.Friendly.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">24sp</item>
        <item name="android:fontFamily">@font/poppins_semibold</item>
    </style>
    
    <style name="TextAppearance.Friendly.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">22sp</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
    </style>
    
    <style name="TextAppearance.Friendly.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
    </style>
    
    <style name="TextAppearance.Friendly.TitleSmall" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
    </style>
    
    <style name="TextAppearance.Friendly.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/poppins_regular</item>
    </style>
    
    <style name="TextAppearance.Friendly.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/poppins_regular</item>
    </style>
    
    <style name="TextAppearance.Friendly.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">@font/poppins_regular</item>
    </style>
    
    <style name="TextAppearance.Friendly.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
    </style>
    
    <style name="TextAppearance.Friendly.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
    </style>
    
    <style name="TextAppearance.Friendly.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/text_hint</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
    </style>
</resources>